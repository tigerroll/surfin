{
  "mappings": [
    {
      "request": {
        "method": "ANY",
        "urlPattern": "/v1/.*",
        "headers": {
          "Authorization": {
            "equalTo": "Bearer test"
          }
        }
      },
      "response": {
        "proxyBaseUrl": "https://api.open-meteo.com"
      }
    }
  ]
}
